<?xml version="1.0" encoding="utf-8"?>
<!-- The detail screen for one country. It scrolls, so it fits on small phones. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/detailFlagImageView"
            android:layout_width="200dp"
            android:layout_height="130dp"
            android:layout_gravity="center_horizontal"
            android:scaleType="fitCenter"
            android:contentDescription="Country flag" />

        <TextView
            android:id="@+id/detailCommonNameTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Common name"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/detailOfficialNameTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Official name"
            android:textSize="16sp"
            android:textColor="@android:color/darker_gray"
            android:gravity="center" />

        <TextView
            android:id="@+id/detailCapitalTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Capital:"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/detailRegionTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Region:"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/detailPopulationTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Population:"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/detailCurrencyTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Currency:"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/detailLanguagesTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Languages:"
            android:textSize="18sp" />

        <Button
            android:id="@+id/favouriteToggleButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Add to favourites" />

    </LinearLayout>

</ScrollView>